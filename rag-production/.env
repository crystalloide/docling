# ─────────────────────────────────────────────────────────
#  Configuration RAG Production — modifiez uniquement ici
# ─────────────────────────────────────────────────────────

# Répertoire contenant les PDFs à ingérer
PDF_DIR=./data/pdfs

# Qdrant
QDRANT_URL=http://localhost:6333
COLLECTION_NAME=prod_documents

# Modèles Ollama
# LLM : llama3.1:8b (vitesse) | qwen3:30b (qualité/raisonnement)
#LLM_MODEL=llama3.1:8b
LLM_MODEL=mistral-nemo:12b
#LLM_MODEL=qwen2.5:7b
#LLM_MODEL=qwen3.5:9b
#LLM_MODEL=qwen3.5:27b   TROP LOURD ! 

EMBED_MODEL=nomic-embed-text

# Paramètres embedding (nomic-embed-text = 768, bge-m3 = 1024)
EMBED_DIM=768

# Découpage des documents
CHUNK_SIZE=1500
CHUNK_OVERLAP=200

# Nombre de chunks retournés lors d'une recherche
TOP_K=15

# HF_TOKEN=hf_xxxxxx
